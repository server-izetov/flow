#!/usr/bin/env bash
# FLOW test runner — called by `bin/flow ci` (and `bin/flow ci --test`).
#
# Modes:
#   bin/test                                  — full suite; fail fast on any issue
#   bin/test --audit                          — full suite; never fails, logs to
#                                               .flow-states/<branch>-audit.log,
#                                               prints terse summary, exit 0
#   bin/test tests/<path>/<name>.rs           — per-file mode; fail fast
#   bin/test tests/<path>/<name>.rs --audit   — per-file mode; never fails
#   bin/test --file <path> [args...]          — single file via rustc --test (dev)
#   bin/test --check <module> [args...]       — fast lib tests, no coverage (dev)
#   bin/test --report                         — re-render cached coverage (dev)
#   bin/test --show <file>                    — annotated source for ONE
#                                               file (dev). Pass basename
#                                               (start_init.rs) or path
#                                               (src/start_init.rs).
#   bin/test --funcs <file>                   — per-function coverage
#                                               (mangled name + count) for
#                                               one source file. Useful when
#                                               --show shows phantom misses
#                                               and you need to see which
#                                               crate-hash instantiations are
#                                               stale (see
#                                               .claude/rules/per-file-coverage-iteration.md
#                                               "Phantom misses").
#   bin/test --module <name>                  — per-module lib coverage (dev)
#   bin/test --adversarial-path               — print canonical Review
#                                               adversarial probe test
#                                               path on stdout (used
#                                               by Phase 4 to discover
#                                               where the adversarial
#                                               agent should write its
#                                               probe). Path lives inside
#                                               the project's test tree
#                                               so cargo nextest discovers
#                                               and executes it; worktree
#                                               removal at Phase 6
#                                               disposes of it as a side
#                                               effect.
#
# Trailing args after `--` on `bin/flow ci --test` forward here as
# filter expressions for nextest.
set -euo pipefail

export RUSTFLAGS="${RUSTFLAGS:-} -D warnings"
export LLVM_COV=/opt/homebrew/opt/llvm/bin/llvm-cov
export LLVM_PROFDATA=/opt/homebrew/opt/llvm/bin/llvm-profdata

# Cap nextest parallelism at floor(cores / 3) so up to 3 concurrent
# FLOW worktrees on this machine don't oversubscribe CPU. With 10
# cores: floor(10/3) = 3 threads/flow → 3 flows × 3 = 9 ≤ 10 cores.
# Honor an explicit caller-supplied NEXTEST_TEST_THREADS.
if [ -z "${NEXTEST_TEST_THREADS:-}" ]; then
  cores="$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 3)"
  cap=$((cores / 3))
  if [ "$cap" -lt 1 ]; then cap=1; fi
  export NEXTEST_TEST_THREADS="$cap"
fi

# Full-suite wall time gate. Per-test gate lives in
# .config/nextest.toml as `slow-timeout` with `terminate-after=1`
# (currently 2s, temporarily relaxed from the 1s target while the
# slow-test backlog clears). Per-file timing gate is intentionally
# absent — per-test discipline subsumes it.
SUITE_TIMEOUT_SECS=600

# --- Global flag parsing ---
AUDIT_MODE=0
PASS_THROUGH=()
for arg in "$@"; do
  case "$arg" in
    --audit) AUDIT_MODE=1 ;;
    *) PASS_THROUGH+=("$arg") ;;
  esac
done
if [ "${#PASS_THROUGH[@]}" -gt 0 ]; then
  set -- "${PASS_THROUGH[@]}"
else
  set --
fi

# --- Review adversarial probe path ---
#
# Phase 4 calls this BEFORE running the suite to learn where the
# adversarial agent should write its probe. The path is relative to
# the worktree root and lives inside `tests/` so cargo nextest
# discovers and executes it via the standard integration-test glob.
# `EXCLUDE_ENTRIES` in `src/prime_check.rs` lists the basename glob
# (`test_adversarial_flow.*`) that prime adds to `.git/info/exclude`
# so the throwaway probe never appears in `git status`.
if [ "${1:-}" = "--adversarial-path" ]; then
  echo "tests/test_adversarial_flow.rs"
  exit 0
fi

# --- Dev-only modes (unchanged behavior) ---

if [ "${1:-}" = "--file" ]; then
  shift
  file="$1"
  shift
  temp_bin=".flow-test-binary"
  trap 'rm -f "$temp_bin"' EXIT
  rustc --test "$file" -o "$temp_bin"
  ./"$temp_bin" "$@"
  exit
fi

if [ "${1:-}" = "--check" ]; then
  shift
  module="$1"
  shift
  exec cargo nextest run --lib -E "test(${module})" "$@"
fi

if [ "${1:-}" = "--report" ]; then
  shift
  exec cargo llvm-cov report --show-missing-lines "$@"
fi

if [ "${1:-}" = "--show" ]; then
  shift
  file="$1"
  shift
  # llvm-cov's --ignore-filename-regex uses POSIX regex without
  # lookaround, so the previously-attempted "match everything BUT
  # target" pattern silently matched nothing and the entire codebase
  # was dumped (12MB+ for a single-file query). Generate the full
  # annotated report and post-filter via awk to the section for the
  # target file. Sections begin with a header of the form
  # `/abs/path/to/file.rs:` and end at the next such header.
  #
  # Accepts either a basename (`start_init.rs`) or a path
  # (`src/start_init.rs`); matches `/<arg>:` at end of header line.
  esc_file="$(printf '%s' "$file" | sed 's/[.]/\\./g')"
  cargo llvm-cov report --text --show-instantiations "$@" \
    | awk -v needle="$esc_file" '
        BEGIN { in_target = 0 }
        /^\/.*\.rs:$/ {
          if ($0 ~ ("/" needle ":$")) {
            in_target = 1
            print
            next
          }
          in_target = 0
          next
        }
        in_target == 1 { print }
      '
  exit
fi

if [ "${1:-}" = "--funcs" ]; then
  shift
  file="$1"
  shift
  # Per-function coverage breakdown for ONE source file via JSON output.
  # cargo-llvm-cov's --show-functions exists but its filename filter
  # doesn't support negative lookahead either, so post-process JSON.
  cargo llvm-cov report --json "$@" 2>/dev/null \
    | jq -r --arg f "$file" '
        .data[].functions[]
        | select(.filenames[0] | test("/src/" + $f + "$"))
        | "\(.count // 0)\t\(.name)"
      ' \
    | sort -n
  exit
fi

if [ "${1:-}" = "--module" ]; then
  shift
  module="$1"
  shift
  echo "=== Running lib tests matching '${module}' ==="
  cargo llvm-cov --lib nextest \
    --no-cfg-coverage \
    --no-clean \
    --status-level pass \
    --final-status-level fail \
    -E "test(${module})" \
    "$@" 2>&1 | awk '
      /^ *PASS / { printf "."; c++; fflush(); next }
      { if (c > 0) { printf "\n\n"; c = 0 } print; fflush() }
      END { if (c > 0) printf "\n" }'
  echo ""
  echo "=== Coverage for ${module} ==="
  cargo llvm-cov report --show-missing-lines 2>&1 | awk -v m="${module}" '
    BEGIN { in_uncov = 0 }
    /^Filename/ { hdr=$0; sep_print=0; next }
    /^---/ { if (sep_print == 0) { sep=$0; sep_print=1 } next }
    /^TOTAL/ { next }
    /^Uncovered Lines:/ { in_uncov = 1; print ""; print "--- Uncovered lines ---"; next }
    in_uncov == 1 {
      if ($1 ~ ("(/|^)" m "\\.rs:$") || $1 ~ ("(/|^)" m "/.+\\.rs:$")) print
      next
    }
    $1 ~ ("(/|^)" m "\\.rs$") || $1 ~ ("(/|^)" m "/.+\\.rs$") {
      if (printed == 0) { print hdr; print sep; printed = 1 }
      print
    }
  '
  exit
fi

# --- Unconditional profraw sweep ---
# Recursive under target/llvm-cov-target so subprocess tests that
# write profraws under nested subdirs (or profraws left behind by
# killed runs) cannot poison the next `cargo llvm-cov report` with
# stale profdata — that merge was the root cause of the multi-minute
# CI pile-up (693M of accumulated profraws). Sweep runs only at the
# start (bin/flow ci --clean is the user-facing reset for when a
# full clear is wanted).
/usr/bin/find target/llvm-cov-target -name "*.profraw" -delete 2>/dev/null || true
/usr/bin/find . -maxdepth 1 -name "default_*.profraw" -delete 2>/dev/null || true

# --- Resolve the audit log path (branch-scoped). ---
# Per FLOW's concurrency model (CLAUDE.md "Local vs Shared State"),
# per-branch artifacts live under .flow-states/ keyed by branch name.
# Using PID would namespace per-process but ignore the branch the run
# is auditing, which is the natural unit for a test-run record.
branch_for_audit() {
  local b
  b="$(git branch --show-current 2>/dev/null || true)"
  if [ -z "$b" ]; then
    b="detached"
  fi
  echo "$b"
}

# --- Per-file mode: bin/test tests/<path>/<name>.rs ---
case "${1:-}" in
  tests/*.rs) PER_FILE=1 ;;
  *) PER_FILE=0 ;;
esac

if [ "$PER_FILE" = "1" ]; then
  test_file="$1"
  shift
  if [ ! -f "$test_file" ]; then
    echo "error: test file not found: $test_file" >&2
    exit 1
  fi
  src_file="${test_file/#tests\//src/}"

  # `-E 'binary(...)'` filters which compiled binaries RUN. Without
  # `--test <name>` cargo still COMPILES all ~112 test binaries in
  # the workspace because any src/ edit forces a re-link of every
  # binary that depends on the `flow_rs` rlib. `--test` scopes
  # compilation to the single mirrored binary, dropping per-file
  # wall time from ~2m to ~10–30s on a lib edit. The `-E` filter is
  # kept as belt-and-suspenders.
  #
  # tests/<subdir>/<name>.rs uses Cargo's directory-form auto-
  # discovery: one binary per directory, named after the directory,
  # with sibling files declared as modules in <subdir>/main.rs. The
  # binary name is the directory basename and the per-module filter
  # scopes execution to the requested file's `mod` block. Top-level
  # tests/<name>.rs keeps the file-basename binary mapping.
  if [[ "$test_file" == tests/*/* ]]; then
    bin_name="$(basename "$(dirname "$test_file")")"
    module_name="$(basename "$test_file" .rs)"
    NEXTEST_ARGS=(--test "${bin_name}" --status-level none --final-status-level fail -E "binary(${bin_name}) and test(/^${module_name}::/)")
  else
    bin_name="$(basename "$test_file" .rs)"
    NEXTEST_ARGS=(--test "${bin_name}" --status-level none --final-status-level fail -E "binary(${bin_name})")
  fi
  COV_ARGS=(--no-cfg-coverage --no-clean)

  if [ "$AUDIT_MODE" = "1" ]; then
    # Audit bypasses cargo-llvm-cov — its own `--profile` flag
    # conflicts with nextest's, swallowing the audit-profile
    # selection. Audit is a diagnostic (find slow/failing tests),
    # so coverage measurement is out of scope here.
    NEXTEST_ARGS+=(--no-fail-fast --profile audit)
    mkdir -p .flow-states
    branch="$(branch_for_audit)"
    run_log=".flow-states/${branch}-audit.log"
    : > "$run_log"
    echo "=== ${bin_name} audit (log: ${run_log}) ==="
    time_start=$SECONDS
    cargo nextest run "${NEXTEST_ARGS[@]}" "$@" >>"$run_log" 2>&1 || true
    elapsed=$((SECONDS - time_start))
    # With profile.audit (no terminate-after), slow tests run to
    # completion; SLOW lines only fire at 60s boundaries. Count
    # unique slow/failed test names, trimming whitespace and
    # stripping ANSI escapes. `set +e` guards against grep
    # returning 1 when no matches exist.
    set +e
    slow_count="$(grep -E '^ *SLOW ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
    fail_count="$(grep -E '^ *FAIL ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
    set -e
    echo "Wall time: ${elapsed}s"
    echo "Slow tests (>60s): ${slow_count}"
    echo "Failed tests: ${fail_count}"
    echo "Full log: ${run_log}"
    exit 0
  fi

  # Normal per-file: fail fast on any issue (nextest's fail-fast +
  # terminate-after handle test/timing failures).
  #
  # Coverage enforcement is a two-step: first run nextest under
  # cargo-llvm-cov with `--no-report` so profraw is captured but no
  # threshold check runs; then invoke `cargo llvm-cov report
  # --fail-under-* --ignore-filename-regex` to scope the threshold
  # to the mirrored src file. Doing it in one command (`cargo
  # llvm-cov --fail-under-* nextest ...`) computes the threshold
  # against the full codebase totals, ignoring the filter — the
  # subcommand form only applies the regex to the printed table,
  # not to the fail-under calculation.
  if [ -f "$src_file" ]; then
    time_start=$SECONDS
    # Step 1: run tests. Capture cargo-llvm-cov output to a tempfile
    # and surface it only on failure. The success path produces a
    # single summary line so callers can sweep many files without
    # drowning in repeated coverage tables.
    nextest_log="$(mktemp)"
    set +e
    cargo llvm-cov "${COV_ARGS[@]}" nextest \
      "${NEXTEST_ARGS[@]}" "$@" >"$nextest_log" 2>&1
    rc=$?
    set -e
    if [ "$rc" -ne 0 ]; then
      cat "$nextest_log" >&2
      rm -f "$nextest_log"
      exit "$rc"
    fi
    rm -f "$nextest_log"
    # Step 2: extract the coverage row for the mirrored src file
    # and assert all three percentages (Regions, Functions, Lines)
    # read 100.00%. We can't use cargo-llvm-cov's
    # `--ignore-filename-regex + --fail-under-*` combination
    # because llvm-cov's regex engine doesn't honor negative
    # lookahead, so the filter silently matches nothing and the
    # threshold evaluates against the full-codebase total.
    #
    # Basenames are unique across src/ in this codebase (verified
    # by `tests/test_placement.rs` indirectly; enforced in practice
    # by the flat-basename convention). Matching on the basename
    # with a trailing whitespace boundary guards against partial
    # matches like `commands/log.rs` being matched by `log.rs`.
    basename_src="$(basename "$src_file")"
    cov_report="$(cargo llvm-cov report 2>&1)"
    cov_line="$(printf '%s\n' "$cov_report" | awk -v f="$basename_src" '
      # Match any line whose first column ends with "/<basename>"
      # or equals "<basename>" exactly.
      $1 == f || $1 ~ "/" f "$" { print; exit }
    ')"
    elapsed=$((SECONDS - time_start))
    if [ -z "$cov_line" ]; then
      # cargo-llvm-cov omits files with zero instrumented regions
      # (e.g., a file that only contains derive macros or type
      # declarations — no executable code to cover). A file with
      # zero regions is trivially at 100% because there is nothing
      # to miss. Treat this as PASS.
      printf '%s  PASS  no-instrumented-regions  (%ss)\n' \
        "$basename_src" "$elapsed"
      exit 0
    fi
    # Report layout: Regions cover in col 4, Functions cover
    # (labeled "Executed") in col 7, Lines cover in col 10.
    regions_pct="$(printf '%s\n' "$cov_line" | awk '{print $4}')"
    funcs_pct="$(printf '%s\n' "$cov_line" | awk '{print $7}')"
    lines_pct="$(printf '%s\n' "$cov_line" | awk '{print $10}')"
    if [ "$regions_pct" = "100.00%" ] && \
       [ "$funcs_pct" = "100.00%" ] && \
       [ "$lines_pct" = "100.00%" ]; then
      printf '%s  PASS  %s / %s / %s  (%ss)\n' \
        "$basename_src" "$regions_pct" "$funcs_pct" "$lines_pct" "$elapsed"
      exit 0
    fi
    printf '%s  FAIL  %s / %s / %s  (%ss)\n' \
      "$basename_src" "$regions_pct" "$funcs_pct" "$lines_pct" "$elapsed" >&2
    exit 1
  fi

  # Meta-test (no mirrored src) — no coverage gate.
  time_start=$SECONDS
  nextest_log="$(mktemp)"
  set +e
  cargo llvm-cov "${COV_ARGS[@]}" nextest "${NEXTEST_ARGS[@]}" "$@" >"$nextest_log" 2>&1
  rc=$?
  set -e
  if [ "$rc" -ne 0 ]; then
    cat "$nextest_log" >&2
    rm -f "$nextest_log"
    exit "$rc"
  fi
  rm -f "$nextest_log"
  elapsed=$((SECONDS - time_start))
  printf '%s  PASS  meta-test  (%ss)\n' "$bin_name" "$elapsed"
  exit 0
fi

# --- Full-suite mode ---
#
# We no longer run `cargo sweep --installed` or `cargo clean -p flow-rs`
# on every full-suite invocation. The Frankenstein-coverage concern
# (stale instrumented binaries from prior source generations merging
# their covmaps into today's report) is addressed by the unconditional
# recursive profraw sweep above — llvm-cov's report only includes
# coverage from the profraws produced by THIS run, so stale instrumented
# binaries in target/llvm-cov-target/debug/deps/ contribute nothing
# when there is no matching profdata for them. `bin/flow ci --clean`
# is the user-facing reset for a true fresh-clone experience.

NEXTEST_ARGS=(--status-level pass --final-status-level fail)
COV_ARGS=(--no-cfg-coverage --no-clean)

if [ "$AUDIT_MODE" = "1" ]; then
  # Audit bypasses cargo-llvm-cov entirely — its own `--profile`
  # flag conflicts with nextest's `--profile`, swallowing the
  # audit-profile selection. Since audit is a diagnostic tool
  # (find slow tests, find failing tests), coverage measurement
  # is out of scope; regular `bin/flow ci` carries the coverage
  # gate.
  NEXTEST_ARGS+=(--no-fail-fast --profile audit)
  mkdir -p .flow-states
  branch="$(branch_for_audit)"
  run_log=".flow-states/${branch}-audit.log"
  : > "$run_log"
  echo "=== Full-suite audit (log: ${run_log}) ==="
  time_start=$SECONDS
  cargo nextest run "${NEXTEST_ARGS[@]}" "$@" >>"$run_log" 2>&1 || true
  elapsed=$((SECONDS - time_start))
  # Count unique slow/failed test names. With profile.audit
  # (no terminate-after), slow tests run to completion; actual
  # durations appear in PASS/FAIL lines and SLOW warnings appear
  # at 60s boundaries. `|| true` keeps set -e from exiting when
  # grep finds no matches; `wc -l | tr -d ' '` normalizes count.
  set +e
  slow_count="$(grep -E '^ *SLOW ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
  fail_count="$(grep -E '^ *FAIL ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
  set -e
  echo "Wall time: ${elapsed}s"
  echo "Slow tests (>60s): ${slow_count}"
  echo "Failed tests: ${fail_count}"
  echo "Full log: ${run_log}"
  exit 0
fi

# Normal full-suite: fail fast on any issue.
#
# Coverage thresholds only apply when the run actually covers the
# whole suite — i.e., no filter args were passed. A filtered run
# (e.g. `bin/flow ci --test -- foo::bar`) exercises a subset of
# tests, so measuring total coverage against 100% is meaningless
# and would always fail the build. The filter path's job is to
# prove the specific test passes and respects the 2s gate; the
# full suite's job is to enforce 100/100/100 coverage globally.
if [ $# -eq 0 ]; then
  COV_ARGS+=(--fail-under-lines 100 --fail-under-regions 100 --fail-under-functions 100)
fi
echo "=== nextest: cargo llvm-cov nextest ==="
time_start=$SECONDS
# Heartbeat + coverage filter + failure classification. The pipeline:
#   cargo llvm-cov ... 2>&1 | tee <log> | awk <filter>
# (a) nextest sees a non-TTY and skips its multi-line animated progress
# bar at the source, (b) tee preserves the full unfiltered stream to a
# branch-scoped log so we can classify the failure cause at the end,
# (c) awk collapses each passing test to a single dot that flushes
# live, and (d) coverage rows that read 100/100/100 on
# Regions/Functions/Lines drop out so only rows with a real gap remain.
# The Branches column always shows "-" here (no branches computed), so
# counting "100.00%" occurrences is sufficient — a row with three of
# them is exactly fully covered. FAIL/LEAK/TIMEOUT, compile output, the
# Summary line, the table header/separators, and the TOTAL line pass
# through verbatim. PIPESTATUS[0] (not $?) gives cargo llvm-cov's exit
# specifically, independent of tee/awk success.
mkdir -p .flow-states
branch="$(branch_for_audit)"
ci_log=".flow-states/${branch}-ci-last.log"
: > "$ci_log"
set +e
cargo llvm-cov "${COV_ARGS[@]}" nextest "${NEXTEST_ARGS[@]}" "$@" 2>&1 | tee "$ci_log" | awk '
  /^ *PASS / { printf "."; c++; fflush(); next }
  /^TOTAL / { if (c > 0) { printf "\n\n"; c = 0 } print; fflush(); next }
  {
    s = $0
    n = gsub(/100\.00%/, "&", s)
    if (n >= 3) next
    if (c > 0) { printf "\n\n"; c = 0 }
    print; fflush()
  }
  END { if (c > 0) printf "\n" }'
rc=${PIPESTATUS[0]}
set -e

if [ "$rc" -ne 0 ]; then
  # Classify the failure so the user sees the real cause above the
  # JSON wrapper ci.rs emits. Nextest prints FAIL/LEAK-FAIL/TIMEOUT
  # lines when tests themselves fail; absence of those markers means
  # the tests passed and cargo llvm-cov's --fail-under-* gate tripped.
  # Layout is a short title line + indented detail lines so the
  # scroll-back reads top-down instead of wrap-right.
  echo "" >&2
  if grep -qE '^ *(FAIL|LEAK-FAIL|TIMEOUT) ' "$ci_log" 2>/dev/null; then
    echo "FAIL — one or more tests failed" >&2
    echo "   See output above." >&2
    echo "   Full log: ${ci_log}" >&2
  elif [ $# -eq 0 ] && grep -q 'tests run:' "$ci_log" 2>/dev/null; then
    echo "FAIL — coverage below 100/100/100 gate" >&2
    echo "   See non-100% rows above." >&2
    echo "   Full log: ${ci_log}" >&2
  else
    echo "FAIL — bin/test exited ${rc}" >&2
    echo "   Full log: ${ci_log}" >&2
  fi
  echo "" >&2
  exit "$rc"
fi
# Slow tests are terminated by nextest (terminate-after=1) and
# appear as TIMEOUT failures, already caught by the rc check above.
elapsed=$((SECONDS - time_start))
if [ "$elapsed" -gt "$SUITE_TIMEOUT_SECS" ]; then
  echo ""
  echo "=== FAIL: suite took ${elapsed}s, limit ${SUITE_TIMEOUT_SECS}s ==="
  exit 1
fi
echo ""
echo "=== PASS (${elapsed}s) ==="
exit 0
